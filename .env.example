# Optional: LLM second-pass polish in the UI.
# Local compose + agent launch work with no keys.

# Copy to .env and fill in (never commit .env):
#   cp .env.example .env

# OpenAI-compatible polish
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=

# xAI
# XAI_API_KEY=
# XAI_MODEL=grok-3-mini

# OpenRouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4.1-mini

# Local OpenAI-compatible (Ollama, LM Studio, vLLM, …)
# PROMPTER_LLM_BASE_URL=http://127.0.0.1:11434/v1
# PROMPTER_LLM_MODEL=llama3.2
# PROMPTER_LLM_API_KEY=none

# Server
# PORT=3847
# HOST=127.0.0.1
