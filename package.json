{
  "name": "prompter",
  "version": "1.1.0",
  "description": "Local app: attach a project folder, pick a coding CLI, type a rough request, get a code-grounded prompt and run it",
  "type": "module",
  "main": "server.js",
  "bin": {
    "prompter": "./bin/prompter.js"
  },
  "scripts": {
    "start": "node start.js",
    "server": "node server.js",
    "dev": "node --watch server.js",
    "cli": "node bin/prompter.js",
    "doctor": "node bin/prompter.js doctor",
    "agents": "node bin/prompter.js agents",
    "list": "node bin/prompter.js list"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "prompts",
    "local",
    "coding-agents",
    "cli",
    "codex",
    "claude",
    "grok",
    "gemini",
    "context"
  ],
  "license": "MIT"
}
