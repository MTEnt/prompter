{
  "name": "prompter",
  "version": "1.4.0",
  "description": "Local app: attach a project, tree-sitter symbol index, rank code for your request, open a coding CLI with a grounded prompt",
  "type": "module",
  "main": "server.js",
  "bin": {
    "prompter": "./bin/prompter.js"
  },
  "scripts": {
    "start": "node start.js",
    "server": "node server.js",
    "dev": "node --watch server.js",
    "cli": "node bin/prompter.js",
    "doctor": "node bin/prompter.js doctor",
    "agents": "node bin/prompter.js agents",
    "list": "node bin/prompter.js list",
    "test": "node scripts/smoke-context.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "prompts",
    "local",
    "coding-agents",
    "cli",
    "codex",
    "claude",
    "grok",
    "gemini",
    "context"
  ],
  "license": "MIT",
  "dependencies": {
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "web-tree-sitter": "^0.26.10"
  }
}
